{
  "id": "openclaw-memory-decay",
  "name": "Memory Decay",
  "description": "Human-like memory with decay and reinforcement for OpenClaw agents",
  "version": "0.1.10",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "serverPort": {
        "type": "number",
        "default": 8100
      },
      "pythonPath": {
        "type": "string"
      },
      "memoryDecayPath": {
        "type": "string"
      },
      "dbPath": {
        "type": "string"
      },
      "autoSave": {
        "type": "boolean",
        "default": true
      },
      "embeddingProvider": {
        "type": "string"
      },
      "embeddingApiKey": {
        "type": "string"
      },
      "embeddingModel": {
        "type": "string"
      },
      "embeddingDim": {
        "type": "number"
      },
      "experimentDir": {
        "type": "string"
      }
    }
  }
}
